SECRET_KEY=your-secret-key-here
DEBUG=True
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:8000/callback/
POWENS_DOMAIN=
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=
POWENS_REDIRECT_URI=http://localhost:8000/callback/powens/
# Stripe — platform keys (required for Financial Connections + webhook verification)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=
# Provider API keys are per-user, entered via the UI (not server-level settings)

# AI Models — override to test different models per task
ANTHROPIC_API_KEY=
# Workers (fast, cheap — Haiku by default)
# AI_MODEL_TRIAGE=claude-haiku-4-5-20251001
# AI_MODEL_EXTRACTION=claude-haiku-4-5-20251001
# AI_MODEL_CORRELATION=claude-haiku-4-5-20251001
# AI_MODEL_RECURRING=claude-haiku-4-5-20251001
# Smart tasks (judgment needed — Sonnet by default)
# AI_MODEL_CLASSIFICATION=claude-sonnet-4-5-20250929
# AI_MODEL_VERIFIER=claude-sonnet-4-5-20250929

# ── Phase 1: Payment Providers (Encaissements) ──
# Fintecture (user provides app_id + app_secret via UI, no env vars needed)
# GoCardless (user provides access_token via UI, no env vars needed)
# PayPlug (user provides secret_key via UI, no env vars needed)
# SumUp (user provides api_key + merchant_code via UI, no env vars needed)

# ── Phase 2: Invoicing Providers (Facturation) ──
# Evoliz (user provides public_key + secret_key + company_id via UI)
# Pennylane (user provides access_token via UI)
# VosFactures (user provides api_token + account_prefix via UI)

# ── Phase 3: Banking (Banque) ──
# Qonto (user provides login + secret_key via UI)

# ── Phase 4: Enrichment (Enrichissement) ──
# Shopify (user provides store_name + access_token via UI)
# PrestaShop (user provides shop_url + api_key via UI)
# WooCommerce (user provides shop_url + consumer_key + consumer_secret via UI)
# Alma (user provides api_key via UI)

# Chorus Pro (government e-invoicing — requires PISTE platform registration)
CHORUS_PRO_CLIENT_ID=
CHORUS_PRO_CLIENT_SECRET=
